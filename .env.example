# GitHub personal access token — used by the data pipeline (sample/ingest).
# Needs no special scopes for public stars; `public_repo` is plenty.
GITHUB_TOKEN=

# ── Ask AI (provider-agnostic, OpenAI-compatible) ────────────────────────────
# The /api/ask Netlify Function talks to any OpenAI-compatible chat-completions
# endpoint via three env vars. Defaults target the Z.AI GLM Coding Plan.

LLM_API_KEY=

# Endpoint root and model id. Examples below — uncomment and fill in.
# LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4    # Z.AI GLM Coding Plan (default)
# LLM_MODEL=glm-4.6

# Other providers (any OpenAI-compatible API works):
#
#   Z.AI pay-as-you-go    base=https://api.z.ai/api/paas/v4              model=glm-4.6
#   OpenAI                base=https://api.openai.com/v1                 model=gpt-4o-mini
#   Groq                  base=https://api.groq.com/openai/v1            model=llama-3.3-70b-versatile
#   Together              base=https://api.together.xyz/v1               model=meta-llama/Llama-3.3-70B-Instruct-Turbo
#   DeepSeek              base=https://api.deepseek.com/v1               model=deepseek-chat
#   Mistral               base=https://api.mistral.ai/v1                 model=mistral-small-latest
#   OpenRouter            base=https://openrouter.ai/api/v1              model=anthropic/claude-sonnet-4-5
#   Fireworks             base=https://api.fireworks.ai/inference/v1     model=accounts/fireworks/models/llama-v3p3-70b-instruct
#   Local (Ollama)        base=http://localhost:11434/v1                 model=llama3.2

# Legacy aliases — still honored, but prefer LLM_* above.
# ZAI_API_KEY=
# ZAI_BASE_URL=
# ZAI_MODEL=
