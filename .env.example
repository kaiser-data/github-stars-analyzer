# GitHub personal access token — used by the data pipeline (sample/ingest).
# Needs no special scopes for public stars; `public_repo` is plenty.
GITHUB_TOKEN=

# Z.AI API key — used by the /api/ask Netlify Function (Ask AI tab).
# Get one at https://z.ai/manage-apikey/apikey-list
ZAI_API_KEY=

# Optional — override the Z.AI model (defaults to glm-4.6).
# ZAI_MODEL=glm-4.6

# Optional — override the Z.AI base URL. Defaults to the GLM Coding Plan
# endpoint (subscription). Use https://api.z.ai/api/paas/v4 for pay-as-you-go.
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
